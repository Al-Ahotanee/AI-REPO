{
  "name": "AI Faculty Repository",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "forwardPorts": [5000, 3000],
  "portsAttributes": {
    "5000": {
      "label": "Backend API",
      "onAutoForward": "ignore"
    },
    "3000": {
      "label": "Frontend SPA",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && mkdir -p uploads",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
